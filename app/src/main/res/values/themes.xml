<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BookNook" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/cream_white</item>
        <item name="android:statusBarColor">@color/cream_white</item>
        <item name="android:navigationBarColor">@color/soft_linen</item>
    </style>

    <style name="Theme.BookNook.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FBF7EE</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_book</item>
        <item name="windowSplashScreenIconBackgroundColor">#FBF7EE</item>
        <item name="postSplashScreenTheme">@style/Theme.BookNook</item>
    </style>
</resources>